<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application>

        <!-- Firebase component discovery: each Firebase library (crashlytics, common,
             installations, etc.) attaches its registrar class name as a <meta-data> child of
             ComponentDiscoveryService. At runtime ComponentDiscovery reads these via
             PackageManager.getServiceInfo(...).metaData — it does NOT start the service.
             PREVIOUSLY this used tools:node="replace" + enabled="false" to avoid a suspected
             ForegroundServiceDidNotStartInTimeException, but that DROPPED all the registrar
             children, so discovery found zero registrars and Crashlytics never initialized.
             tools:node="merge" preserves the children while keeping the service non-exported.
             The service is plain (no foregroundServiceType) and is never started at runtime. -->
        <service
            android:name="com.google.firebase.components.ComponentDiscoveryService"
            android:exported="false"
            tools:node="merge" />

    </application>

</manifest>
