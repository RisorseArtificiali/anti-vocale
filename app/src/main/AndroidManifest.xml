<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Storage permissions for model file access -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <!-- Foreground service for inference -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Post notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".BridgeApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AntiVocale"
        tools:targetApi="34">

        <!-- Native libraries for LiteRT-LM GPU acceleration -->
        <uses-native-library android:name="libvndksupport.so" android:required="false"/>
        <uses-native-library android:name="libOpenCL.so" android:required="false"/>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:supportsPictureInPicture="true"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
            android:theme="@style/Theme.AntiVocale">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- BroadcastReceiver for Tasker requests -->
        <receiver
            android:name=".receiver.TaskerRequestReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.antivocale.app.PROCESS_REQUEST" />
            </intent-filter>
        </receiver>

        <!-- BroadcastReceiver for model preloading -->
        <receiver
            android:name=".receiver.ModelPreloadReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.antivocale.app.PRELOAD_MODEL" />
            </intent-filter>
        </receiver>

        <!-- Activity for receiving shared audio files -->
        <activity
            android:name=".receiver.ShareReceiverActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/mpeg" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/mp4" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/ogg" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/wav" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/x-wav" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/aac" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/flac" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/3gpp" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/ogg" />
            </intent-filter>
        </activity>

        <!-- Share target aliases: each appears as a separate option in the Android share sheet -->
        <activity-alias
            android:name=".ShareParakeet"
            android:targetActivity=".receiver.ShareReceiverActivity"
            android:enabled="false"
            android:exported="true"
            android:label="@string/share_target_parakeet"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/ogg" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".ShareWhisper"
            android:targetActivity=".receiver.ShareReceiverActivity"
            android:enabled="false"
            android:exported="true"
            android:label="@string/share_target_whisper"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/ogg" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".ShareGemma"
            android:targetActivity=".receiver.ShareReceiverActivity"
            android:enabled="false"
            android:exported="true"
            android:label="@string/share_target_gemma"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/ogg" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".ShareQwen3"
            android:targetActivity=".receiver.ShareReceiverActivity"
            android:enabled="false"
            android:exported="true"
            android:label="@string/share_target_qwen3"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/ogg" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".ShareNemotron"
            android:targetActivity=".receiver.ShareReceiverActivity"
            android:enabled="false"
            android:exported="true"
            android:label="@string/share_target_nemotron"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/ogg" />
            </intent-filter>
        </activity-alias>

        <!-- Transparent trampoline for Tasker: brings app to foreground so InferenceService
             can be started legally on Android 12+. Finishes immediately, never visible. -->
        <activity
            android:name=".receiver.TaskerTrampolineActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- Debug-only activity for automated benchmarking (exported for adb am start) -->
        <activity
            android:name=".receiver.BenchmarkActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- BroadcastReceiver for notification actions -->
        <receiver
            android:name=".receiver.NotificationActionReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.antivocale.app.COPY_TRANSCRIPTION" />
                <action android:name="com.antivocale.app.SHARE_TRANSCRIPTION" />
                <action android:name="com.antivocale.app.SHARE_BACK" />
            </intent-filter>
        </receiver>

        <!-- BroadcastReceiver for capturing chosen app from share chooser -->
        <receiver
            android:name=".receiver.ChooserBroadcastReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- Prevent Firebase ComponentDiscoveryService from being started as a foreground service.
             It's only needed for meta-data component discovery at build time, not at runtime.
             Without this, Android can crash the app with ForegroundServiceDidNotStartInTimeException. -->
        <service
            android:name="com.google.firebase.components.ComponentDiscoveryService"
            android:enabled="false"
            android:exported="false"
            tools:node="replace" />

        <!-- Foreground service for inference processing -->
        <service
            android:name=".service.InferenceService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="ai_inference" />
        </service>

        <!-- Foreground service for model download + extraction -->
        <service
            android:name=".service.ExtractionService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="model_download" />
        </service>

        <!-- Per-app language service for backward compatibility (API 21-32) -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>

    </application>

</manifest>
